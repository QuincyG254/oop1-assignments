#include <stdio.h>
#define PI 3.142

int main() {
    float r, h, volume, surface_area;

    printf("Enter radius: ");
    scanf("%f", &r);

    printf("Enter height: ");
    scanf("%f", &h);

    volume = PI * r * r * h;
    surface_area = 2 * PI * r * (r + h);

    printf("Volume: %.2f\n", volume);
    printf("Surface Area: %.2f\n", surface_area);

    return 0;
}
