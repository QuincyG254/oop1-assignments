#include <stdio.h>

int main() {
    float attendance, marks;

    printf("Enter attendance (%%): ");
    scanf("%f", &attendance);

    printf("Enter average marks: ");
    scanf("%f", &marks);

    if (attendance >= 75 && marks >= 40) {
        printf("Eligible for exams\n");
    } else {
        printf("Not eligible\n");
    }

    return 0;
}
#include <stdio.h>

int main() {
    int units;
    float bill;

    printf("Enter water units consumed: ");
    scanf("%d", &units);

    if (units <= 30) {
        bill = units * 20;
    } else if (units <= 60) {
        bill = (30 * 20) + (units - 30) * 25;
    } else {
        bill = (30 * 20) + (30 * 25) + (units - 60) * 30;
    }

    printf("Total water bill: %.2f KES\n", bill);

    return 0;
}
#include <stdio.h>

int main() {
