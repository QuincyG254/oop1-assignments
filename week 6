#include <stdio.h>

int main() {
    float revenue[7], total = 0;

    for(int i = 0; i < 7; i++) {
        printf("Enter revenue for day %d: ", i+1);
        scanf("%f", &revenue[i]);
        total += revenue[i];
    }

    printf("Total: %.2f\n", total);
    printf("Average: %.2f\n", total/7);

    return 0;
}
