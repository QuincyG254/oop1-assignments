#include <stdio.h>

float calculateElectricBill(int units) {
    if (units <= 100)
        return units * 10;
    else if (units <= 200)
        return (100 * 10) + (units - 100) * 15;
    else
        return (100 * 10) + (100 * 15) + (units - 200) * 20;
}

float calculateFare(float distance) {
    return distance * 50;
}

float convertToCelsius(float f) {
    return (f - 32) * 5 / 9;
}

int main() {
    printf("Electric Bill (250 units): %.2f\n", calculateElectricBill(250));
    printf("Fare (10km): %.2f\n", calculateFare(10));
    printf("Celsius (98.6F): %.2f\n", convertToCelsius(98.6));

    return 0;
}
